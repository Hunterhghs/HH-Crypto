# Public HH mint on Solana (full base58 address)
NEXT_PUBLIC_HH_MINT=

# Solana pubkey that should receive USDC (merchant treasury)
NEXT_PUBLIC_MERCHANT_WALLET=

# Usually 9 for many SPL meme-style tokens — set to match your mint
NEXT_PUBLIC_HH_DECIMALS=9

# Optional: reliable RPC improves quote reliability under load
# NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
