# Public HH mint on Solana — real base58 token address only (copy from Solscan / wallet;
# do not paste descriptive text from docs into Cloudflare / Vercel).
NEXT_PUBLIC_HH_MINT=

# Solana pubkey that should receive USDC — real base58 address only
NEXT_PUBLIC_MERCHANT_WALLET=

# Usually 9 for many SPL tokens — set to match your mint
NEXT_PUBLIC_HH_DECIMALS=9

# Optional: reliable RPC improves quote reliability under load
# NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
